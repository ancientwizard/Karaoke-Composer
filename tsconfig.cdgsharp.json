{
  // TypeScript config for running CDGSharp CLI via tsx.
  // CommonJS avoids Node.js ESM strict named-export binding, which rejects
  // interface imports that have no runtime value.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "verbatimModuleSyntax": false,
    "noEmit": true
  },
  "include": ["src/CDGSharp/**/*"]
}
